@baseUrl = http://localhost:9000

### ─── Create Experience ───────────────────────────────────────────────────────

# Sukses — dengan gambar dan koordinat
POST {{baseUrl}}/api/experiences
Content-Type: application/json

{
  "experience_type": "nature",
  "title": "Sunrise di Puncak Sikunir",
  "address": "Sikunir, Kejajar, Wonosobo, Jawa Tengah",
  "description": "Nikmati keindahan matahari terbit dari puncak Sikunir dengan pemandangan Dataran Tinggi Dieng yang menakjubkan.",
  "thumbnail_url": "https://example.com/images/sikunir.jpg",
  "lat": -7.2132,
  "lng": 109.9199,
  "base_price": 150000,
  "images": [
    { "image_url": "https://example.com/images/sikunir-1.jpg", "is_primary": true },
    { "image_url": "https://example.com/images/sikunir-2.jpg", "is_primary": false }
  ]
}

###

# Sukses — minimal (tanpa gambar, thumbnail, dan koordinat)
POST {{baseUrl}}/api/experiences
Content-Type: application/json

{
  "experience_type": "culinary",
  "title": "Tour Kuliner Dieng",
  "address": "Pasar Dieng, Banjarnegara",
  "description": "Jelajahi kuliner khas Dieng mulai dari carica, kentang goreng, hingga mie ongklok.",
  "base_price": 75000
}

###

# Error: experience_type kosong (400 Bad Request)
POST {{baseUrl}}/api/experiences
Content-Type: application/json

{
  "title": "Telaga Warna",
  "address": "Dieng, Banjarnegara",
  "description": "Danau warna-warni di kawasan Dieng.",
  "base_price": 50000
}

###

