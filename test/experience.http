Content-Type: application/json

{
  "experience_type": "nature",
  "title": "Telaga Warna",
  "address": "Dieng, Banjarnegara",
  "description": "Danau warna-warni di kawasan Dieng."
}

### ─── Search Experience ───────────────────────────────────────────────────────

# Semua experience (default page=1, size=10)
GET {{baseUrl}}/api/experiences

###

# Filter by keyword
GET {{baseUrl}}/api/experiences?key=sikunir

###

# Filter by type
GET {{baseUrl}}/api/experiences?type=nature

###

# Filter keyword + type
GET {{baseUrl}}/api/experiences?key=dieng&type=culinary

###

# Custom pagination
GET {{baseUrl}}/api/experiences?page=1&size=5

###

# Page jauh melebihi total data (hasil data kosong)
GET {{baseUrl}}/api/experiences?page=999&size=10
