@baseUrl = http://localhost:9000

# Ganti dengan ID yang valid setelah membuat data
@amenityId   = your_amenity_id_here
@propertyId  = your_property_id_here
@rentableId  = your_rentable_id_here

### ─── List Amenities ───────────────────────────────────────────────────────────

# Sukses — daftar semua amenity
GET {{baseUrl}}/api/amenities

###

### ─── Create Amenity ───────────────────────────────────────────────────────────

# Sukses — amenity lengkap dengan icon dan kategori
POST {{baseUrl}}/api/amenities
Content-Type: application/json

{
  "name": "WiFi",
  "icon": "wifi",
  "category": "connectivity"
}

###

# Sukses — amenity tanpa icon dan kategori
POST {{baseUrl}}/api/amenities
Content-Type: application/json

{
  "name": "Parkir"
}

###

# Sukses — amenity fasilitas kamar mandi
POST {{baseUrl}}/api/amenities
Content-Type: application/json

{
  "name": "Air Panas",
  "icon": "shower",
  "category": "bathroom"
}

###

# Sukses — amenity fasilitas umum
POST {{baseUrl}}/api/amenities
Content-Type: application/json

{
  "name": "Kolam Renang",
  "icon": "waves",
  "category": "facilities"
}

###

# Error: name kosong (400 Bad Request)
POST {{baseUrl}}/api/amenities
Content-Type: application/json

{
  "icon": "wifi",
  "category": "connectivity"
}

###

### ─── Set Property Amenities ───────────────────────────────────────────────────

# Sukses — set amenities untuk property (menggantikan seluruh daftar lama)
PUT {{baseUrl}}/api/properties/{{propertyId}}/amenities
Content-Type: application/json

{
  "amenity_ids": ["{{amenityId}}"]
}

###

# Sukses — kosongkan semua amenity property
PUT {{baseUrl}}/api/properties/{{propertyId}}/amenities
Content-Type: application/json

{
  "amenity_ids": []
}

###

# Error: property tidak ditemukan (404 Not Found)
PUT {{baseUrl}}/api/properties/property-id-tidak-ada/amenities
Content-Type: application/json

{
  "amenity_ids": []
}

###

### ─── Set Rentable Amenities ───────────────────────────────────────────────────

# Sukses — set amenities untuk rentable
PUT {{baseUrl}}/api/rentables/{{rentableId}}/amenities
Content-Type: application/json

{
  "amenity_ids": ["{{amenityId}}"]
}

###

# Sukses — kosongkan semua amenity rentable
PUT {{baseUrl}}/api/rentables/{{rentableId}}/amenities
Content-Type: application/json

{
  "amenity_ids": []
}

###

# Error: rentable tidak ditemukan (404 Not Found)
PUT {{baseUrl}}/api/rentables/rentable-id-tidak-ada/amenities
Content-Type: application/json

{
  "amenity_ids": []
}

###

### ─── Get Property (verifikasi amenities muncul di response) ──────────────────

# Amenities properti dan masing-masing rentable akan tampil di GET /api/properties/:propertyId
GET {{baseUrl}}/api/properties/your_property_id_here

###
